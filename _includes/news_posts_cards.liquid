<div class="news-cards-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 0.5rem;">
  {% assign shown = 0 %}
  {% for post in site.posts %}
    {% if shown >= 3 %}{% break %}{% endif %}
    {% if post.thumbnail == blank %}{% continue %}{% endif %}
    {% assign shown = shown | plus: 1 %}
    <a href="{{ post.url | prepend: site.baseurl }}" style="text-decoration: none; color: inherit;">
      <div style="border: 1px solid var(--global-divider-color); border-radius: 8px; overflow: hidden; height: 100%;">
        {% if post.thumbnail contains '://' %}
          <img src="{{ post.thumbnail }}" alt="{{ post.title }}" style="width: 100%; height: 130px; object-fit: cover;">
        {% else %}
          <img src="{{ post.thumbnail | relative_url }}" alt="{{ post.title }}" style="width: 100%; height: 130px; object-fit: cover;">
        {% endif %}
        <div style="padding: 0.6rem;">
          <p style="font-size: 0.72em; color: #999; margin: 0 0 0.2rem;">{% include date_format.liquid format='short' date=post.date %}</p>
          <p style="font-size: 0.82em; margin: 0; line-height: 1.3;">{{ post.title }}</p>
        </div>
      </div>
    </a>
  {% endfor %}
</div>
